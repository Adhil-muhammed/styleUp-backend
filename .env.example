# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# PostgreSQL (Supabase — primary)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.icmshcvapojlqvgpkyat.supabase.co:5432/postgres
POSTGRES_HOST=db.icmshcvapojlqvgpkyat.supabase.co
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=[YOUR-PASSWORD]
POSTGRES_DB=postgres
POSTGRES_SSL=true
POSTGRES_POOL_MAX=10
POSTGRES_POOL_MIN=2
POSTGRES_POOL_IDLE_TIMEOUT_MS=30000
POSTGRES_POOL_CONNECTION_TIMEOUT_MS=5000

# MongoDB (secondary / document store)
MONGODB_URI=mongodb://localhost:27017/styleup
MONGO_PORT=27017
MONGO_DB=styleup

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
