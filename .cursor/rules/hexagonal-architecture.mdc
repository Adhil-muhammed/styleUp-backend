## Before / After (hypothetical — no feature modules exist yet)

**Violating service (do not write):**

```typescript
// src/modules/bookings/bookings.service.ts — BAD
import { InjectModel } from '@nestjs/mongoose';
import { Model } from 'mongoose';
import { Booking, BookingDocument } from './booking.schema';

@Injectable()
export class BookingsService {
  constructor(@InjectModel(Booking.name) private readonly bookingModel: Model<BookingDocument>) {}

  async create(dto: CreateBookingDto) {
    if (dto.endTime <= dto.startTime) throw new BadRequestException('Invalid range'); // domain rule mixed with ORM
    return this.bookingModel.create(dto); // exposes document shape
  }
}
```

**Hex-aligned service:**

```typescript
// src/modules/bookings/bookings.service.ts — GOOD
@Injectable()
export class BookingsService {
  constructor(
    @Inject(BOOKING_REPOSITORY) private readonly bookings: BookingRepositoryPort,
  ) {}

  async create(dto: CreateBookingDto): Promise<Booking> {
    const booking = Booking.create({ ...dto }); // domain factory enforces end > start
    return this.bookings.save(booking);
  }
}
```

